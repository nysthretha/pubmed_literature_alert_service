RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

POSTGRES_URL=postgres://pubmed:pubmed@postgres:5432/pubmed?sslmode=disable
POSTGRES_USER=pubmed
POSTGRES_PASSWORD=pubmed
POSTGRES_DB=pubmed

# NCBI E-utilities credentials
# Empty API key => 3 req/sec cap; a key => 10 req/sec cap.
# Request one at https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com
PUBMED_TOOL_NAME=pubmed-alerts

# How often the scheduler tick runs. On each tick it finds queries whose
# per-row poll_interval_seconds has elapsed since last_polled_at and polls
# them. Default: 5 minutes.
SCHEDULER_TICK_SECONDS=300
