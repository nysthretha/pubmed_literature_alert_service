RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

POSTGRES_URL=postgres://pubmed:pubmed@postgres:5432/pubmed?sslmode=disable
POSTGRES_USER=pubmed
POSTGRES_PASSWORD=pubmed
POSTGRES_DB=pubmed

# NCBI E-utilities credentials
# Empty API key => 3 req/sec cap; a key => 10 req/sec cap.
# Request one at https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com
PUBMED_TOOL_NAME=pubmed-alerts

# Scheduler tick cadence. Per-query poll intervals live in the DB.
SCHEDULER_TICK_SECONDS=300

# --- Auth ------------------------------------------------------------------
# Whether to set the Secure flag on session cookies. ALWAYS true in production.
# Set to false only for local development without HTTPS; a startup WARN is
# logged so reduced-security mode is visible on every boot.
AUTH_COOKIE_SECURE=true

# --- Digest worker -----------------------------------------------------------

# Delivery mode:
#   file       = render HTML to ./previews/<timestamp>.html; no SMTP, no DB writes
#   mailpit    = send to the local Mailpit service (UI at http://localhost:8025)
#   smtp       = real SMTP with STARTTLS + auth
#   brevo_api  = HTTPS API to Brevo. Use this on platforms that block outbound
#                SMTP (e.g. Railway Hobby plan). Requires BREVO_API_KEY below.
DIGEST_MODE=file

DIGEST_SEND_HOUR=7
DIGEST_TIMEZONE=Europe/Istanbul
DIGEST_RECIPIENT=your-email@example.com
DIGEST_SUBJECT_PREFIX=PubMed Alerts

# SMTP config (only used when DIGEST_MODE=smtp)
# For Gmail: generate an app password at
#   https://myaccount.google.com/apppasswords
# (requires 2-step verification on the account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Brevo HTTPS API (only used when DIGEST_MODE=brevo_api).
# Generate at: https://app.brevo.com/settings/keys/api → "Generate a new API key".
# This is NOT the SMTP password — it's a separate API key with its own scope.
# The SMTP_FROM address must be verified in Brevo's senders list:
#   https://app.brevo.com/senders/list
BREVO_API_KEY=
