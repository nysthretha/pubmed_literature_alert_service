{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    // baseUrl is deprecated in TS 6 / removed in TS 7. `paths` entries with
    // explicit `./` prefixes resolve against the tsconfig directory directly
    // — no baseUrl required. This is the migration path TypeScript recommends.
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
